# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Google Sign-In (Web Client ID; same as used in Flutter serverClientId)
GOOGLE_CLIENT_ID=987311737711-ook0mrmtt827pd25afngb2jrivia4ccu.apps.googleusercontent.com
# Optional: Android OAuth client ID (if token is issued for Android app, add it here)
# GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Database Configuration - MySQL
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=visionart_db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Optional: Forgot password email (if not set, in dev the reset token is returned in the API response)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=VisionArt <noreply@visionart.app>
# FRONTEND_RESET_URL=https://yourapp.com/reset-password
